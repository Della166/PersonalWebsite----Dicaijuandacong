# Cloudflare R2 (media CDN)
R2_ACCOUNT_ID=your_cloudflare_account_id
R2_ACCESS_KEY_ID=your_r2_access_key
R2_SECRET_ACCESS_KEY=your_r2_secret_key
R2_BUCKET_NAME=personal-website-media
R2_PUBLIC_URL=https://media.yoursite.com

# Notion (optional, for blog sync)
NOTION_API_KEY=your_notion_integration_key
NOTION_DATABASE_ID=your_blog_database_id

# WeChat (optional, for content:wechat)
WECHAT_APP_ID=
WECHAT_APP_SECRET=
